rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isVerifiedUser() {
      return isLoggedIn() &&
        (request.auth.token.email_verified == true ||
         request.auth.token.phone_number != null ||
         request.auth.token.firebase.sign_in_provider in ['google.com', 'apple.com']);
    }

    // ── Users collection ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Generations collection ────────────────────────────────────────────────
    match /generations/{docId} {
      allow get: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isLoggedIn() && isVerifiedUser() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Admin stats ───────────────────────────────────────────────────────────
    match /admin/stats {
      allow read: if isAdmin();
      allow write: if isLoggedIn();
    }

    match /admin/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Plans collection (subscription plans) ────────────────────────────────
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Transactions collection ───────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && isVerifiedUser();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Credits logs ─────────────────────────────────────────────────────────
    match /credits_logs/{logId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // ── Projects collection ───────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isLoggedIn() && isVerifiedUser();
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Prompts collection ────────────────────────────────────────────────────
    match /prompts/{promptId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Blogs collection ──────────────────────────────────────────────────────
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Notifications collection ──────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isLoggedIn() && (resource.data.target == 'all' || resource.data.target == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isLoggedIn() && (resource.data.target == 'all' || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Settings collection ───────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Admin Logs collection ─────────────────────────────────────────────────
    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ── Orders collection ─────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && isVerifiedUser() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Payments collection ───────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // ── Public config ─────────────────────────────────────────────────────────
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
